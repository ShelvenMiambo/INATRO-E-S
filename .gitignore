# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# dados: mantemos data/processed/*.json e public/questions/*.webp (usados pela app).
# data/images (PNG brutos recortados) e data/raw (fonte original) sao intermediarios
# pesados do pipeline de extracao e nao precisam de estar no repo.
/data/local.db*
/data/images/
/data/raw/
/.wrangler/
